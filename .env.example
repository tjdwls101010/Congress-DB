# Postgres 연결 정보 (docker-compose.yml과 일치시킬 것)
POSTGRES_USER=congress
POSTGRES_PASSWORD=congress_dev
POSTGRES_DB=congress
# 호스트 5432가 비어 있으면 5432, 다른 PG가 있으면 5433 등으로 비워둠
POSTGRES_PORT=5433

# 애플리케이션이 읽는 단일 변수 — psycopg가 이 URL로 연결
DATABASE_URL=postgresql://congress:congress_dev@localhost:5433/congress
